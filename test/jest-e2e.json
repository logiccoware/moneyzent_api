{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "diagnostics": true }]
  },
  "setupFiles": ["<rootDir>/jest-e2e.setup.ts"],
  "moduleNameMapper": {
    "^@/lib/auth$": "<rootDir>/mocks/auth.ts",
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
