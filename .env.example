# Application
APP_ENV=development
PORT=3000
# PostgreSQL
DATABASE_URL=postgresql://postgres:secret@localhost:5432/monovra-dev
DATABASE_POOL_SIZE=10
# Better Auth
BETTER_AUTH_SECRET=anysecret
BETTER_AUTH_URL=http://localhost:3000
# CORS
CORS_ORIGIN=http://localhost:3001
# Swagger
SWAGGER_ENABLED=true
SWAGGER_BASIC_AUTH_USER=swagger
SWAGGER_BASIC_AUTH_PASS=change-me-123
# OpenTelemetry / Dash0 (prod only — obtain values from Dash0 dashboard)
OTEL_ENABLED=false
# OTEL_SERVICE_NAME=moneyzent-api
# OTEL_EXPORTER_OTLP_ENDPOINT=https://ingress.us-west-2.aws.dash0.com
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer <your-dash0-token>